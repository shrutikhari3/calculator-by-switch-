
#include <stdio.h>

int main(){

    int num1,num2,result;
    char op;

    printf("Enter first number: \n");
    scanf("%d", &num1);

    printf("Enter operator ( + , - , * , / ):\n");
    scanf(" %c", &op);

    printf("Enter second number:\n");
    scanf("%d", &num2);

    switch(op){

        case '+':
          result = num1 + num2;
          printf("Result  = %d" , result);
          break;

        case '-':
          result = num1-num2;
          printf("Result =  %d" , result);
          break;

        case '*':
          result = num1*num2;
          printf("Result =  %d" , result);
          break;

        case '/':
            if(num2==0){
                printf("division not perform on zero");
            }else{
                result = num1 / num2;
                printf("Result = %d" , result);
            }
            break;

            default:
            printf("invalid operator");
    }
    
    return 0;
    }
